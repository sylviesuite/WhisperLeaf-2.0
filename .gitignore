# ========================================
# WhisperLeaf .gitignore
# ========================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------- Build / Distribution ----------
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---------- Virtual Environments ----------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
whisperleaf_env/

# ---------- Environment Files ----------
.env
.env.*
.envrc

# ---------- Logs ----------
*.log
logs/

# ---------- Databases ----------
*.db
*.sqlite
*.sqlite3

# ---------- Cache ----------
.cache/
*.cache
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ---------- Test / Coverage ----------
htmlcov/
.coverage
.coverage.*
.tox/
.nox/

# ---------- Jupyter ----------
.ipynb_checkpoints/

# ---------- Documentation ----------
docs/_build/
site/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ---------- Cursor ----------
.cursor/
.cursorignore
.cursorindexingignore

# ---------- WhisperLeaf Sensitive Config ----------
config/.env
config/config.yaml
config/constitutional_rules.yaml

# ---------- WhisperLeaf User Data ----------
data/
memories/
emotional_data/
personal_content/

# ---------- WhisperLeaf Models ----------
models/
*.model
*.bin

# ---------- WhisperLeaf Cache ----------
content_cache/
rss_cache/

# ---------- WhisperLeaf System ----------
.whisperleaf/
whisperleaf.conf

# ---------- Backups ----------
backups/
*.backup
*.bak

# ---------- Temporary ----------
tmp/
temp/
.tmp/

# ---------- Keys ----------
*.key
*.pem
*.crt

# ---------- Misc ----------
celerybeat-schedule
celerybeat.pid
.python-version
.pypirc