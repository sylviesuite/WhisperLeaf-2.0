# WhisperLeaf .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/
whisperleaf_env/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/

# Netlify static site: track beta ZIP and installer (global `downloads/` rule would otherwise ignore this folder)
!whisperleaf-site/downloads/
!whisperleaf-site/downloads/*.zip
!whisperleaf-site/downloads/*.exe

# PyInstaller build artifacts (keep source, ignore outputs)
installer/build/
installer/dist/
installer/__pycache__/
installer/*.spec

eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Logs
logs/
*.log

# Database / user data
data/
*.db
*.sqlite
*.sqlite3

# Secrets / config
.env
.envrc
config/.env
config/config.yaml
config/constitutional_rules.yaml

# Encryption keys
*.key
*.pem
*.crt

# Temporary files
tmp/
temp/
.tmp/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation
docs/_build/
site/
mkdocs documentation
/site

# Jupyter
.ipynb_checkpoints

# Python version / tooling
.python-version
.pdm-python
.pdm-build/
.pixi
__pypackages__/
.ruff_cache/
.pypirc

# WhisperLeaf specific
memories/
emotional_data/
personal_content/
models/
*.model
*.bin
content_cache/
rss_cache/
.whisperleaf/
whisperleaf.conf

# Cursor
.cursorignore
.cursorindexingignore