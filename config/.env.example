# WhisperLeaf Environment Variables Template
# Copy this file to .env and customize for your installation

# Security Keys (CHANGE THESE!)
SECRET_KEY=your-super-secret-key-change-this-immediately
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data
JWT_SECRET_KEY=your-jwt-secret-key-for-authentication

# Database Configuration
DATABASE_URL=sqlite:///data/whisperleaf.db
DATABASE_ENCRYPTION_KEY=your-database-encryption-key

# API Configuration
API_HOST=localhost
API_PORT=8000
API_DEBUG=false

# External Services (Optional)
# Uncomment and configure if using enhanced AI features
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1

# Content Curation (Optional)
# RSS_USER_AGENT=WhisperLeaf/1.0
# WEB_SCRAPING_ENABLED=true

# Backup Configuration
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key
BACKUP_DIRECTORY=backups/

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/whisperleaf.log

# Development Settings
DEVELOPMENT_MODE=false
DEBUG_MODE=false

# Performance Settings
WORKERS=1
MAX_CONNECTIONS=100

# Feature Flags
ADVANCED_AI_ENABLED=false
PLUGIN_SYSTEM_ENABLED=false
WEB_INTERFACE_ENABLED=false

# Crisis Response Configuration
CRISIS_DETECTION_ENABLED=true
EMERGENCY_CONTACT_EMAIL=your-emergency-contact@example.com
EMERGENCY_CONTACT_PHONE=+1-555-0123

# Privacy Settings
TELEMETRY_ENABLED=false
ANALYTICS_ENABLED=false
EXTERNAL_LOGGING_ENABLED=false

# Constitutional AI Settings
CONSTITUTIONAL_AI_ENABLED=true
STRICT_MODE_ENABLED=true
AUDIT_LOGGING_ENABLED=true

# Timezone Configuration
TIMEZONE=UTC

# Session Configuration
SESSION_TIMEOUT=3600
REMEMBER_ME_DURATION=2592000  # 30 days

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# SSL/TLS Configuration (for production)
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# Monitoring and Health Checks
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=false
PROMETHEUS_ENABLED=false

# Content Processing
MAX_CONTENT_SIZE=10485760  # 10MB
CONTENT_PROCESSING_TIMEOUT=30

# Memory Management
MAX_MEMORY_ENTRIES=1000000
MEMORY_CLEANUP_INTERVAL=604800  # 7 days

# Emotional Analysis
EMOTION_CONFIDENCE_THRESHOLD=0.5
CRISIS_THRESHOLD=0.7
MOOD_TRACKING_ENABLED=true

# Backup Settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400  # 24 hours
BACKUP_RETENTION_DAYS=90
BACKUP_COMPRESSION_ENABLED=true

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=300  # 5 minutes
CACHE_MAX_SIZE=1000

# Testing Configuration
TEST_MODE=false
MOCK_EXTERNAL_SERVICES=false

# Localization
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,it

# Accessibility
ACCESSIBILITY_FEATURES_ENABLED=true
SCREEN_READER_SUPPORT=true

# Mobile Configuration
MOBILE_API_ENABLED=false
MOBILE_PUSH_NOTIFICATIONS=false

# Integration Settings
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=your-webhook-secret-key

# Data Export Settings
EXPORT_ENABLED=true
EXPORT_FORMAT=json
EXPORT_ENCRYPTION_ENABLED=true

# Compliance Settings
GDPR_COMPLIANCE_ENABLED=true
CCPA_COMPLIANCE_ENABLED=true
HIPAA_COMPLIANCE_ENABLED=false

# Advanced Features
SEMANTIC_SEARCH_ENABLED=false
PREDICTIVE_ANALYSIS_ENABLED=false
MACHINE_LEARNING_ENABLED=false

# Plugin System
PLUGIN_DIRECTORY=plugins/
PLUGIN_SECURITY_ENABLED=true
PLUGIN_SANDBOXING_ENABLED=true

# Network Configuration
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Email Configuration (for notifications)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Notification Settings
NOTIFICATIONS_ENABLED=true
DESKTOP_NOTIFICATIONS=true
EMAIL_NOTIFICATIONS=false
SMS_NOTIFICATIONS=false

